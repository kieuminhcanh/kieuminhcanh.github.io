[
  {
    "name": "v-row",
    "props": {
      "align": "center",
      "justify": "center",
      "class": "h-100"
    },
    "slots": {
      "default": [
        {
          "name": "v-col",
          "props": {
            "cols": "12",
            "sm": "8",
            "md": "6"
          },
          "slots": {
            "default": [
              {
                "name": "v-card",
                "slots": {
                  "default": [
                    {
                      "name": "v-layout",
                      "slots": {
                        "default": [
                          {
                            "name": "v-app-bar",
                            "props": {
                              "color": "primary",
                              "prominent": true
                            },
                            "slots": {
                              "default": [
                                {
                                  "name": "v-app-bar-nav-icon",
                                  "props": {
                                    "variant": "text"
                                  },
                                  "events": [
                                    {
                                      "name": "click",
                                      "statements": "drawer = !drawer"
                                    }
                                  ],
                                  "slots": {}
                                },
                                {
                                  "name": "v-toolbar-title",
                                  "slots": {
                                    "default": "Navigation drawer"
                                  }
                                },
                                {
                                  "name": "v-spacer",
                                  "slots": {}
                                },
                                {
                                  "name": "v-btn",
                                  "props": {
                                    "variant": "text",
                                    "icon": "mdi-magnify"
                                  },
                                  "slots": {}
                                },
                                {
                                  "name": "v-btn",
                                  "props": {
                                    "variant": "text",
                                    "icon": "mdi-filter"
                                  },
                                  "slots": {}
                                },
                                {
                                  "name": "v-btn",
                                  "props": {
                                    "variant": "text",
                                    "icon": "mdi-dots-vertical"
                                  },
                                  "slots": {}
                                }
                              ]
                            }
                          },
                          {
                            "name": "v-navigation-drawer",
                            "model": {
                              "key": "drawer",
                              "value": true
                            },
                            "slots": {
                              "default": [
                                {
                                  "name": "v-list",
                                  "props": {
                                    "items": [
                                      {
                                        "title": "Foo",
                                        "value": "foo"
                                      },
                                      {
                                        "title": "Bar",
                                        "value": "bar"
                                      },
                                      {
                                        "title": "Fizz",
                                        "value": "fizz"
                                      },
                                      {
                                        "title": "Buzz",
                                        "value": "buzz"
                                      }
                                    ]
                                  }
                                }
                              ]
                            }
                          },
                          {
                            "name": "v-main",
                            "props": {
                              "style": "height: 500px;"
                            },
                            "slots": {
                              "default": [
                                {
                                  "name": "v-card-text",
                                  "slots": {
                                    "default": "The navigation drawer will appear from the bottom on smaller size screens."
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
]
