                                  "props": {
                                    "items": [
                                      {
                                        "title": "Menu item 1",
                                        "value": 1
                                      },
                                      {
                                        "title": "Menu item 2",
                                        "value": 2
                                      },
                                      {
                                        "title": "Menu item 3",
                                        "value": 3
                                      }
                                    ]
                                  }
                                }
                              ]
                            }
                          }
                        ]
                      }
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
